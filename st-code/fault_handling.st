(*
    Fault Handling and Alarm Logic
    Handles jam, overload, emergency stop, safety door, and reset behavior.
*)

IF NOT E_STOP_OK THEN
    E_STOP_FAULT := TRUE;
    FAULT_LATCHED := TRUE;
END_IF;

IF NOT SAFETY_DOOR_CLOSED THEN
    SAFETY_DOOR_FAULT := TRUE;
    FAULT_LATCHED := TRUE;
END_IF;

IF NOT MOTOR_OVERLOAD_OK THEN
    MOTOR_OVERLOAD_FAULT := TRUE;
    FAULT_LATCHED := TRUE;
END_IF;

IF ENTRY_SENSOR AND NOT EXIT_SENSOR AND CONVEYOR_MOTOR_RUN THEN
    JAM_TIMER_ENABLE := TRUE;
ELSE
    JAM_TIMER_ENABLE := FALSE;
END_IF;

IF JAM_TIMER_DONE THEN
    JAM_FAULT := TRUE;
    FAULT_LATCHED := TRUE;
END_IF;

IF FAULT_LATCHED THEN
    CONVEYOR_MOTOR_RUN := FALSE;
    AUTO_CYCLE_ACTIVE := FALSE;
    ALARM_LIGHT := TRUE;
    HORN := TRUE;
ELSE
    ALARM_LIGHT := FALSE;
    HORN := FALSE;
END_IF;

IF RESET_PB
   AND E_STOP_OK
   AND SAFETY_DOOR_CLOSED
   AND MOTOR_OVERLOAD_OK
   AND NOT TEMP_CRITICAL THEN

    E_STOP_FAULT := FALSE;
    SAFETY_DOOR_FAULT := FALSE;
    MOTOR_OVERLOAD_FAULT := FALSE;
    JAM_FAULT := FALSE;
    FAULT_LATCHED := FALSE;
    HORN := FALSE;

END_IF;
