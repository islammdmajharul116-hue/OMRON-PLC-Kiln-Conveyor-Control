(*
    Thermal Sensor Feedback Logic
    Monitors kiln unloading zone temperature.
*)

TEMP_WARNING_LIMIT := 650;
TEMP_CRITICAL_LIMIT := 750;
TEMP_SAFE_RESTART_LIMIT := 600;

IF TEMP_SENSOR >= TEMP_WARNING_LIMIT THEN
    TEMP_WARNING := TRUE;
ELSE
    TEMP_WARNING := FALSE;
END_IF;

IF TEMP_SENSOR >= TEMP_CRITICAL_LIMIT THEN
    TEMP_CRITICAL := TRUE;
    FAULT_LATCHED := TRUE;
    ALARM_LIGHT := TRUE;
    CONVEYOR_MOTOR_RUN := FALSE;
END_IF;

IF TEMP_SENSOR <= TEMP_SAFE_RESTART_LIMIT AND RESET_PB THEN
    TEMP_CRITICAL := FALSE;
END_IF;

IF TEMP_WARNING AND NOT TEMP_CRITICAL THEN
    READY_LIGHT := FALSE;
END_IF;
